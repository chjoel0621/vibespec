{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/chjoel0621/vibespec/sot.schema.json",
  "title": "VibeSpec SOT",
  "description": "Structural contract. Cross-reference and coverage rules are enforced by scripts/validate-sot.mjs.",
  "type": "object",
  "additionalProperties": false,
  "description-note": "schemaVersion enum + optional initiative make this a STRUCTURAL SUPERSET of 1.0 and 1.1. validate-sot.mjs enforces the version-conditional rules (1.1 requires initiative; 1.0 forbids initiative/boundary).",
  "required": ["schemaVersion", "title", "prd", "requirements", "ia", "flow"],
  "properties": {
    "schemaVersion": { "enum": ["1.0", "1.1"] },
    "title": { "$ref": "#/$defs/nonEmptyString" },
    "lang": { "enum": ["ko", "en"] },
    "initiative": { "$ref": "#/$defs/initiative" },
    "prd": { "$ref": "#/$defs/prd" },
    "requirements": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/requirement" } },
    "ia": { "$ref": "#/$defs/ia" },
    "flow": { "$ref": "#/$defs/flow" }
  },
  "$defs": {
    "nonEmptyString": { "type": "string", "minLength": 1 },
    "stringArray": { "type": "array", "items": { "type": "string" } },
    "featureRef": { "type": "string", "pattern": "^F[1-9][0-9]*(?::[0-9]+)?$" },
    "slug": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
    "digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "initiative": {
      "type": "object",
      "additionalProperties": false,
      "required": ["productId", "id", "path", "status", "parent"],
      "properties": {
        "productId": { "$ref": "#/$defs/slug" },
        "id": { "$ref": "#/$defs/slug" },
        "path": { "type": "string", "pattern": "^[1-9][0-9]*(-[1-9][0-9]*)*$" },
        "status": { "enum": ["proposed", "approved", "implemented", "dropped"] },
        "parent": {
          "type": "object",
          "additionalProperties": false,
          "required": ["scopeId", "canonicalization", "digest"],
          "properties": {
            "scopeId": { "$ref": "#/$defs/slug" },
            "canonicalization": { "const": "sot-c14n-v1" },
            "digest": { "$ref": "#/$defs/digest" }
          }
        }
      }
    },
    "boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scopeId", "pageId"],
      "properties": {
        "scopeId": { "$ref": "#/$defs/slug" },
        "pageId": { "type": "string", "pattern": "^P[1-9][0-9]*$" }
      }
    },
    "status": { "enum": ["todo", "doing", "done"] },
    "priority": { "enum": ["high", "mid", "low"] },
    "acceptance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["text", "done"],
      "properties": { "text": { "$ref": "#/$defs/nonEmptyString" }, "done": { "type": "boolean" } }
    },
    "prd": {
      "type": "object",
      "additionalProperties": false,
      "description-note": "Required set is role-conditional (parent 1.0 = full, initiative 1.1 = lean) and enforced in validate-sot.mjs. oneLiner/goal are plain strings here so a lean initiative may leave them empty; non-emptiness is required only for the parent role in code.",
      "properties": {
        "oneLiner": { "type": "string" },
        "goal": { "type": "string" },
        "whyNow": { "type": "string" },
        "category": { "type": "string" },
        "platforms": { "$ref": "#/$defs/stringArray" },
        "problem": { "$ref": "#/$defs/nonEmptyString" },
        "solution": { "$ref": "#/$defs/nonEmptyString" },
        "alternatives": { "type": "string" },
        "differentiator": { "type": "string" },
        "targets": { "type": "array", "items": { "$ref": "#/$defs/persona" } },
        "scenarios": { "type": "array", "items": { "$ref": "#/$defs/scenario" } },
        "northStar": { "type": "string" },
        "kpis": { "type": "array", "items": { "$ref": "#/$defs/kpi" } },
        "inScope": { "$ref": "#/$defs/stringArray" },
        "nonGoals": { "$ref": "#/$defs/stringArray" },
        "assumptions": { "$ref": "#/$defs/stringArray" },
        "risks": { "$ref": "#/$defs/stringArray" },
        "openQuestions": { "$ref": "#/$defs/stringArray" },
        "constraints": { "$ref": "#/$defs/stringArray" }
      }
    },
    "persona": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "role", "needs", "pain"],
      "properties": { "name": { "$ref": "#/$defs/nonEmptyString" }, "role": { "type": "string" }, "needs": { "type": "string" }, "pain": { "type": "string" } }
    },
    "scenario": {
      "type": "object",
      "additionalProperties": false,
      "required": ["text"],
      "properties": { "text": { "$ref": "#/$defs/nonEmptyString" }, "start": { "oneOf": [{ "const": "" }, { "type": "string", "pattern": "^P[1-9][0-9]*$" }] } }
    },
    "kpi": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "target", "baseline", "method", "refs"],
      "properties": { "name": { "$ref": "#/$defs/nonEmptyString" }, "target": { "type": "string" }, "baseline": { "type": "string" }, "method": { "type": "string" }, "refs": { "type": "array", "items": { "$ref": "#/$defs/featureRef" } } }
    },
    "requirement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "desc", "status", "priority", "acceptance", "features"],
      "properties": {
        "id": { "type": "string", "pattern": "^R[1-9][0-9]*$" }, "title": { "$ref": "#/$defs/nonEmptyString" }, "desc": { "type": "string" },
        "status": { "$ref": "#/$defs/status" }, "priority": { "$ref": "#/$defs/priority" }, "acceptance": { "type": "array", "items": { "$ref": "#/$defs/acceptance" } },
        "features": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/feature" } }
      }
    },
    "feature": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "desc", "status", "priority", "acceptance", "specs"],
      "properties": {
        "id": { "type": "string", "pattern": "^F[1-9][0-9]*$" }, "title": { "$ref": "#/$defs/nonEmptyString" }, "desc": { "type": "string" },
        "status": { "$ref": "#/$defs/status" }, "priority": { "$ref": "#/$defs/priority" }, "acceptance": { "type": "array", "items": { "$ref": "#/$defs/acceptance" } },
        "specs": { "type": "array", "items": { "$ref": "#/$defs/spec" } }
      }
    },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "desc", "acceptance"],
      "properties": { "title": { "$ref": "#/$defs/nonEmptyString" }, "desc": { "type": "string" }, "acceptance": { "type": "array", "items": { "$ref": "#/$defs/acceptance" } } }
    },
    "ia": {
      "type": "object", "additionalProperties": false, "required": ["sections"],
      "properties": { "sections": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/section" } } }
    },
    "section": {
      "type": "object", "additionalProperties": false, "required": ["id", "title", "pages"],
      "properties": { "id": { "type": "string", "pattern": "^S[1-9][0-9]*$" }, "title": { "$ref": "#/$defs/nonEmptyString" }, "pages": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/page" } } }
    },
    "page": {
      "type": "object", "additionalProperties": false, "required": ["id", "title", "type", "refs", "children"],
      "properties": { "id": { "type": "string", "pattern": "^P[1-9][0-9]*$" }, "title": { "$ref": "#/$defs/nonEmptyString" }, "type": { "enum": ["top", "page", "action"] }, "refs": { "type": "array", "items": { "$ref": "#/$defs/featureRef" } }, "boundary": { "$ref": "#/$defs/boundary" }, "children": { "type": "array", "items": { "$ref": "#/$defs/page" } } }
    },
    "flow": {
      "type": "object", "additionalProperties": false, "required": ["start", "transitions"],
      "properties": { "start": { "type": "string", "pattern": "^P[1-9][0-9]*$" }, "transitions": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/transition" } } }
    },
    "transition": {
      "oneOf": [
        { "type": "object", "additionalProperties": false, "required": ["from", "to"], "properties": { "from": { "type": "string", "pattern": "^P[1-9][0-9]*$" }, "to": { "type": "string", "pattern": "^P[1-9][0-9]*$" } } },
        { "type": "object", "additionalProperties": false, "required": ["from", "to", "ref"], "properties": { "from": { "type": "string", "pattern": "^P[1-9][0-9]*$" }, "to": { "type": "string", "pattern": "^P[1-9][0-9]*$" }, "ref": { "$ref": "#/$defs/featureRef" } } },
        { "type": "object", "additionalProperties": false, "required": ["from", "to", "label"], "properties": { "from": { "type": "string", "pattern": "^P[1-9][0-9]*$" }, "to": { "type": "string", "pattern": "^P[1-9][0-9]*$" }, "label": { "$ref": "#/$defs/nonEmptyString" } } }
      ]
    }
  }
}
